# Day 1

label day_1:
    call ensure_main_ambience from _call_ensure_main_ambience
    call init_day_clock(20, 30) from _call_init_day_clock

    scene expression bg_path("start-game")
    with dissolve

    narr "Понедельник. Во дворе влажный снег и желтый свет фонарей — как будто их не меняли с советских времен."
    narr "Паша идет медленно, чувствуя, как в плечах еще держится тяжесть от смены."
    p "Если без приключений — через сорок минут буду дома."

    call day1_route_choice from _call_day1_route_choice
    call encounter_gopniks_day1 from _call_encounter_gopniks_day1
    call encounter_yard_guy_day1 from _call_encounter_yard_guy_day1
    call encounter_oldwoman_day1 from _call_encounter_oldwoman_day1
    call day1_home_approach from _call_day1_home_approach

    $ day += 1
    jump week_loop

label day1_route_choice:
    scene expression bg_path("/buildings/factory_exit_id_2")
    with dissolve

    narr "У проходной два пути: через ярко освещенную остановку и вдоль киосков или через дворы, где обычно тише, но темнее."

    menu:
        "Срезать через дворы.":
            $ toughness += 1
            p "Срежу. Быстрее пройду, быстрее забуду этот день."
            narr "Он сворачивает в арку, где сквозняк гоняет пакет по плитке, как мелкое перекати-поле."

        "Идти через остановку и киоски.":
            call pass_time(10) from _call_pass_time
            $ empathy += 1
            $ day1_found_safe_route = True
            p "Лучше дольше, зато люди вокруг."
            narr "Мимо проезжает троллейбус. Внутри тепло и свет, но до дома всего несколько кварталов."

    return

label encounter_gopniks_day1:
    scene expression bg_path("/garages/garage_id_2")
    with dissolve

    call show_right(["gopnik", "sanek"], ["default", "idle"]) from _call_show_right

    narr "У старых гаражей к нему выходит Санек — местный парень, которого Паша знал еще со школы."
    gop "О, Пашка. Живой после смены?"
    p "Как видишь."
    gop "Мы тут стоим, обсуждаем дела. Ну и ты уважение району покажи."

    menu:
        "Отдать 10 рублей и не тянуть разговор.":
            if money >= 10:
                $ money -= 10
                $ day1_paid_gopniks = True
                p "Держи, Сань. Сегодня без споров."
                gop "Нормально. Ты всегда был ровный."
                narr "Санек прячет деньги без улыбки, будто сам устал от этого ритуала."
            else:
                call pass_time(5) from _call_pass_time_1
                p "Пусто. Реально пусто."
                gop "Тогда словами отрабатывай."
                call stress_up(1) from _call_stress_up

        "Поговорить о футболе, чтобы разрядить обстановку.":
            $ day1_talked_football = True
            p "Ладно, не начинай. Скажи лучше, за кого топишь в этом сезоне?"
            gop "За Динамо, как и батя. Только сезон мертвый, сам видишь."
            p "А вы все еще катаетесь на выезды?"
            gop "Когда есть деньги. Раньше думал: околофутбол — это романтика."
            gop "Электрички, баннеры, весь район в шарфах."
            gop "А потом понял: чаще это просто холод, драки."
            p "Зато ты на стадионе живой. На заводе иногда вообще не чувствуешь, что день прошел."
            gop "Вот. Поэтому и ходим. Там хотя бы ясно, за кого ты и кто рядом стоит."
            p "Если честно, мне бы сейчас просто чай и тишину."
            gop "Ха. Стареем, Пашка. Ладно, проходи. Сегодня без налога."
            $ empathy += 1

        "Надавить и пройти силой характера.":
            p "Сань, я не кошелек на ножках. Дай дорогу."
            if toughness >= 1:
                gop "Ладно, вижу, кипишь не нужен. Иди."
                $ toughness += 1
            else:
                gop "Разговор не в той тональности. Значит, будет по-плохому."
                narr "Санек резко толкает тебя в грудь, прижимает к железной двери гаража и выворачивает карманы."
                $ stolen = money
                $ money = 0
                gop "Вот так быстрее. [stolen] рублей — плата за неуважение."
                p "Ты серьезно?"
                gop "Абсолютно. В следующий раз следи за языком."
                call stress_up(1) from _call_stress_up_1
                $ toughness -= 1

    call hide_right from _call_hide_right
    return

label encounter_yard_guy_day1:
    scene expression bg_path("/buildings/magazine_id_1")
    with dissolve

    call show_right(["boy", "guy", "igor"], ["default", "idle"]) from _call_show_right_1

    narr "На углу магазина Пашу догоняет парень лет тридцати в синей куртке."
    guy "Слушай, брат, сигареты не найдется?"
    p "Не курю."
    guy "И правильно. Я вот бросал три раза, все равно возвращаюсь."

    menu:
        "Разговориться по-человечески.":
            p "Как сам вообще? Выглядишь выжатым."
            guy "Да как у всех. С утра на рынке, вечером подработка на разгрузке."
            guy "Слушай... Я вчера ночью видел во дворе человека без лица."
            p "Без лица?"
            guy "Да. Будто кожа гладкая, как на манекене, и ни глаз, ни рта."
            guy "Он стоял у мусорки, а потом просто шагнул в тень и исчез."
            menu:
                "Спросить про жизнь и поддержать.":
                    p "Ты давно в таком ритме?"
                    guy "Третий год. Днем работа, ночью мысли, что так и пройдет вся молодость."
                    p "Ты держишься. Это уже много."
                    guy "Спасибо. Обычно меня только торопят."
                    $ empathy += 1

                "Попросить рассказать анекдот.":
                    p "Ладно, мрак мраком. Есть анекдот на разрядку?"
                    guy "Есть: "
                    guy "Пришел мужик к врачу: 'Доктор, у меня бессонница'."
                    guy "Врач: 'Считайте овец'. Мужик: 'Пробовал. На трехстах решил, что надо брать их оптом и открывать ферму'."
                    p "Ха, полезная бессонница."
                    $ empathy += 1

                "Договориться выпить пиво на неделе.":
                    p "Если переживем эту неделю, возьмем по пиву у ларька."
                    guy "Договорились. В пятницу после девяти я там."
                    p "Значит, увидимся."
                    $ day1_agreed_beer = True
                    $ empathy += 1

        "Отвесить неприятную шутку про его лысеющую голову.":
            p "Слушай, тебе не сигареты бросать надо, а волосы ловить, пока не сбежали."
            guy "Смешно... Очень."
            narr "Парень отворачивается и мгновенно закрывается в себе."
            $ empathy -= 1

        "Сказать, что спешишь, и идти дальше.":
            p "Извини, домой надо, ноги отваливаются."
            guy "Понимаю. Удачи тебе."

    call hide_right from _call_hide_right_1
    return

label encounter_oldwoman_day1:
    scene expression bg_path("/courtyards/yard_id_2")
    with dissolve

    call play_horror_stinger("anomaly", 3.0) from _call_play_horror_stinger
    call show_right(["oldw", "oldwoman", "babka"], ["default", "idle"]) from _call_show_right_2

    narr "У деревянной лавки сидит пожилая женщина в платке."
    narr "Лицо у нее доброе, почти деревенское, но пальцы слишком длинные — тонкие, как вязальные спицы."
    oldw "Сынок, ты не проводишь до третьего подъезда? Голова дурная сегодня."

    menu:
        "Помочь и поддержать под локоть.":
            $ day1_helped_oldwoman = True
            $ empathy += 1
            p "Конечно, давайте. Тут скользко, ступеньки опасные."
            oldw "Спасибо тебе. Сейчас редко кто останавливается, все бегут, будто за ними гонятся."
            p "Может, так и есть."
            oldw "Не теряй в себе мягкость, сынок. Жесткие люди первыми ломаются."
            if "фонарик" not in inventory:
                oldw "Я в темноте уже почти не выхожу: ноги не те и глаза подводят."
                oldw "А тебе по этим дворам ходить каждый вечер. Тебе он нужнее."
                oldw "Возьми фонарик."
                call add_item("фонарик") from _call_add_item

        "Спросить прямо, что с ее руками.":
            p "Извините за вопрос... с руками что-то случилось?"
            oldw "На швейной фабрике с шестнадцати лет. Нитки, иглы, ночные смены."
            oldw "Сначала болели кисти, потом будто вытянулись кости. Врачей тогда не было."
            p "Понятно."
            narr "Ответ звучит обычно, почти бытово. Но от ее неподвижного взгляда по спине идет холод."
            call stress_up(1) from _call_stress_up_2

        "Промолчать и пройти мимо.":
            p "Извините, я опаздываю."
            narr "За спиной слышится медленный скрип лавки, как будто кто-то встал и смотрит вслед."
            call stress_up(2) from _call_stress_up_3

    call hide_right from _call_hide_right_2
    call restore_main_ambience from _call_restore_main_ambience
    return

label day1_home_approach:
    scene expression bg_path("/entrances/entrance_id_1")
    with dissolve

    if day1_helped_oldwoman and day1_talked_football:
        narr "Подходя к своему подъезду, Паша вдруг понимает: сегодня в этом районе с ним говорили как с человеком, а не как с функцией."
        p "Странный вечер. Тяжелый, но не пустой."
        $ empathy += 1
    elif day1_paid_gopniks:
        narr "В кармане стало заметно легче. Паша считает в уме оставшиеся деньги до аванса и морщится."
        p "Так и живем: платишь за тишину, будто она чья-то собственность."
    else:
        narr "Фонарь над подъездом мигает три раза и загорается ровно в тот момент, когда Паша достает ключи."
        p "Первый день недели. Уже неплохо."

    call stop_day_clock from _call_stop_day_clock
    return
